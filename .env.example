# Insuvit Environment Variables
# Salin file ini menjadi ".env" dan sesuaikan dengan konfigurasi server Anda

# Server Configuration
ADDR=:8080
WEB_DIR=web

# Database
DB_PATH=data/insuvit.db

# Admin Credentials (Ganti ini di production!)
ADMIN_USER=admin
ADMIN_PASS=insuvit123

# Security (Ganti dengan string acak yang panjang di production!)
SESSION_SECRET=super-secret-key-for-insuvit-session
